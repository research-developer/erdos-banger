# erdos-banger environment configuration
# Copy to .env and fill in your values

# =============================================================================
# LLM PROVIDERS (for erdos ask/loop commands)
# =============================================================================

# OpenAI API (for scripts/llm-openai.sh)
# Model: gpt-5.2-pro (max reasoning, best for math proofs)
# Reasoning effort: xhigh (highest available tier)
# Docs: https://platform.openai.com/docs/models/gpt-5.2-pro
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-5.2-pro
OPENAI_REASONING_EFFORT=xhigh

# Anthropic API (for scripts/llm-anthropic.sh)
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-opus-4-5-20251101

# Google API (for Gemini - used by Marker PDF conversion)
GOOGLE_API_KEY=your-gemini-key-here

# Default LLM command (used by erdos ask/loop)
ERDOS_LLM_COMMAND=./scripts/llm.sh

# Optional per-task routing (SPEC-032)
# If unset, commands fall back to ERDOS_LLM_COMMAND.
ERDOS_LLM_COMMAND_MATH=./scripts/llm.sh
ERDOS_LLM_COMMAND_CODE=./scripts/llm.sh
ERDOS_LLM_COMMAND_COPILOT=./scripts/llm.sh

# =============================================================================
# FORMAL PROVERS
# =============================================================================

# Harmonic Aristotle (Lean prover)
# Docs: see `docs/_vendor-docs/harmonic-aristotle/README.md`
ARISTOTLE_API_KEY=arstl-your-key-here
ERDOS_ARISTOTLE_COMMAND=aristotle

# =============================================================================
# ACADEMIC METADATA APIS
# =============================================================================

# Email for "polite pool" - faster responses from OpenAlex/Crossref
ERDOS_MAILTO=your-email@example.com

# OpenAlex (Primary metadata source)
# API key is OPTIONAL but recommended for higher limits
# Get your key at: https://openalex.org/users/me
OPENALEX_API_KEY=your-openalex-api-key-here

# arXiv API - No API key required (rate limit: 1 req/3 sec)
# Crossref API - No API key required (use ERDOS_MAILTO for polite pool)

# =============================================================================
# RESEARCH APIS (SPEC-029+)
# =============================================================================

# Exa Research API (Agentic literature synthesis)
# Get your key at: https://exa.ai/
# EXA_API_KEY=your-exa-api-key-here
# ERDOS_EXA_CACHE_TTL=24
# ERDOS_EXA_CACHE_PATH=literature/cache/exa

# Semantic Scholar API (Citation context extraction - SPEC-030)
# OPTIONAL - works without key but rate-limited (100 req/5 min shared pool)
# With key: 1 req/sec dedicated rate limit
# Get your key at: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=your-semantic-scholar-api-key-here
# ERDOS_S2_CACHE_TTL=7
# ERDOS_S2_CACHE_PATH=literature/cache/s2

# zbMATH Open API - No API key required
# ERDOS_ZBMATH_CACHE_TTL=30
# ERDOS_ZBMATH_CACHE_PATH=literature/cache/zbmath
