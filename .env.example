# erdos-banger environment configuration
# Copy to .env and fill in your values

# =============================================================================
# LLM PROVIDERS (for erdos ask/loop commands)
# =============================================================================

# OpenAI API (for scripts/llm-openai.sh)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-5.2
# Reasoning effort: none, low, medium, high, xhigh
OPENAI_REASONING_EFFORT=xhigh

# Anthropic API (for scripts/llm-anthropic.sh)
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-opus-4-5-20251101

# Google API (for Gemini - used by Marker PDF LLM mode)
# GOOGLE_API_KEY=your-gemini-key

# Default LLM command (used by erdos ask/loop)
ERDOS_LLM_COMMAND=./scripts/llm.sh

# =============================================================================
# ACADEMIC METADATA APIS (all are FREE, no keys required!)
# =============================================================================

# Email for "polite pool" - faster responses from OpenAlex/Crossref
# No API keys needed - just add your email for priority access
ERDOS_MAILTO=your-email@example.com

# OpenAlex (Primary - 271M+ works, 100k requests/day)
# No API key required! Just add email above for polite pool.
# Docs: https://docs.openalex.org/

# arXiv API (Secondary - for LaTeX source)
# No API key required! Rate limit: 1 request/3 seconds
# Docs: https://info.arxiv.org/help/api/

# Crossref API (Fallback - for DOI metadata)
# No API key required! Add email above for polite pool.
# Docs: https://www.crossref.org/documentation/retrieve-metadata/rest-api/

# =============================================================================
# PDF CONVERSION (Optional - spec-019, v2.0+)
# =============================================================================

# Marker LLM backend selection (when using --use-llm flag)
# Options: gemini (default), claude, openai, ollama, vertex
# Uses existing API keys above (GOOGLE_API_KEY, ANTHROPIC_API_KEY, OPENAI_API_KEY)

# For local LLM via Ollama (no API costs):
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# PyTorch device override (auto-detected by default)
# TORCH_DEVICE=cuda    # NVIDIA GPU
# TORCH_DEVICE=mps     # Apple Silicon
# TORCH_DEVICE=cpu     # CPU only
